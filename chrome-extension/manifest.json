{
  "manifest_version": 3,
  "name": "Task Agent",
  "version": "1.0",
  "description": "Gestion de tâches avec Claude AI",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Task Agent"
  },
  "permissions": ["storage", "alarms", "notifications", "tabs"],
  "host_permissions": ["https://api.anthropic.com/*", "<all_urls>"],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}